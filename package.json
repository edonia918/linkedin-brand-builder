{
  "name": "launchbrand-backend",
  "version": "1.0.0",
  "description": "Backend API for LaunchBrand authentication and subscriptions",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "vite",
    "dev:server": "nodemon server.js",
    "build": "vite build && cp workspace.html about.html how-it-works.html contact.html styles.css script.js dist/ && cp -r images dist/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "openai": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
